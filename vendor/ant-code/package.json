{
  "name": "@ant-code/cli",
  "version": "1.3.0-taxamask.1",
  "description": "First-party Ant-Code Agent Center runtime embedded by TaxaMask.",
  "type": "module",
  "private": true,
  "bin": {
    "ant-code": "./src/cli/index.js",
    "lab-agent": "./src/cli/index.js"
  },
  "files": [
    "config/lab-agent.high-sensitivity-template.json",
    "config/lab-agent.lab-template.json",
    "config/skills/",
    "scripts/build-dashboard-assets.js",
    "scripts/check-dashboard-assets.js",
    "scripts/check-syntax.js",
    "scripts/dashboard-assets.js",
    "scripts/mock-gateway.js",
    "scripts/verify-gateway-compat.js",
    "src/",
    "tests/",
    "npm-shrinkwrap.json",
    "package-lock.json",
    "tsconfig.json"
  ],
  "scripts": {
    "start": "node src/cli/index.js",
    "doctor": "node src/cli/index.js doctor",
    "mock-gateway": "node scripts/mock-gateway.js",
    "check": "npm run check:syntax && npm run check:dashboard-assets",
    "check:syntax": "node scripts/check-syntax.js",
    "check:dashboard-assets": "node scripts/check-dashboard-assets.js",
    "verify:gateway": "node scripts/verify-gateway-compat.js",
    "build:dashboard-assets": "node scripts/build-dashboard-assets.js",
    "verify:release": "npm run check && npm run verify:gateway",
    "test": "node --test tests/embedded-runtime.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@vscode/ripgrep": "1.18.0",
    "ink": "^6.8.0",
    "katex": "^0.17.0",
    "mermaid": "^11.16.0",
    "react": "^19.2.7",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "postject": "^1.0.0-alpha.6"
  }
}
