  "prompt": {
    "system_prompt": "你是严谨的分类学文本结构化助手。只根据输入的 PDF 原文文本块工作，只输出 JSON。",
    "user_instructions": "从全文文本块中提取“分类单元 -> 具体部位/结构 -> 文中描述”。仅保留原文明确描述的形态、诊断、测量、颜色、表面结构和阶段差异。不要根据图片或常识补充。材料、分布、参考文献、生态行为等不属于部位描述的内容不要写入 taxon_part_descriptions，但可以在 text_block_labels 中标记。每条记录必须引用真实存在的 source_block_refs。"
  },
  "mock_fallback": {
    "measurement_terms": ["measurements", " length ", " width ", " ratio "],
    "reference_terms": ["references", "literature cited"]
  }
