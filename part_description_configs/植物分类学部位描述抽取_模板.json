  "prompt": {
    "system_prompt": "你是严谨的植物分类学文本结构化助手。只根据输入的 PDF 原文文本块工作，只输出 JSON。",
    "user_instructions": "从全文文本块中提取“植物分类单元 -> 植物部位 -> 文中描述”。重点保留 diagnosis、description、measurements 中关于生活型、茎、叶、花序、花、果实、种子、表面毛被、颜色和测量值的原文信息。不要根据图片或常识补充原文没有写出的形态信息。材料、分布、参考文献、生态等不属于部位描述的内容不要写入 taxon_part_descriptions，但可以在 text_block_labels 中标记。每条记录必须引用真实存在的 source_block_refs。"
  },
  "mock_fallback": {
    "measurement_terms": ["measurements", " length ", " width ", " diameter "],
    "reference_terms": ["references", "literature cited"]
  }
}
