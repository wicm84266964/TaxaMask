{
  "modelAlias": null,
  "models": [],
  "allowedHosts": [
    "duckduckgo.com",
    "html.duckduckgo.com",
    "github.com",
    "raw.githubusercontent.com",
    "api.github.com",
    "r.jina.ai"
  ],
  "networkMode": "approved-web",
  "lab": {
    "gatewayUrl": null,
    "gatewayProtocol": "openai-chat"
  },
  "context": {
    "maxMessages": 100000,
    "maxBytes": 2000000,
    "maxTokens": 200000,
    "keepRecentMessages": 8,
    "tailTurns": 2,
    "preserveRecentTokens": 8000,
    "summaryBytes": 65536,
    "promptCompactRatio": 0.64,
    "resumeMaxMessages": 100000,
    "resumeMaxTokens": 200000,
    "resumeMaxBytes": 2000000,
    "inFlightCompactRatio": null,
    "inFlightKeepRecentTools": null
  },
  "limits": {
    "maxToolRounds": null
  },
  "agents": {
    "maxRounds": null,
    "orchestration": {
      "maxParallelReadonlyAgentRuns": 2
    },
    "delegationGuard": {
      "enabled": true,
      "mode": "remind",
      "softThreshold": 3,
      "strongThreshold": 5
    },
    "backgroundWakeup": {
      "enabled": true,
      "defaultForModelAgentRun": false,
      "maxConcurrentBackground": 3,
      "defaultWaitFor": "all",
      "autoQueueParentPrompt": true,
      "maxWakeSummaryBytes": 12000
    },
    "reviewGate": {
      "enabled": true,
      "mode": "remind",
      "todoThreshold": 4,
      "requireForWrites": false,
      "requireForHighRisk": false
    },
    "vision": {
      "enabled": true,
      "model": null,
      "autoUseWhenMainModelTextOnly": true
    },
    "modelTiers": {},
    "budgets": {
      "defaults": {
        "maxDurationMs": 1800000,
        "maxOutputBytes": 320000
      },
      "readonly-researcher": {
        "maxDurationMs": 1200000,
        "maxOutputBytes": 320000
      },
      "web-researcher": {
        "maxDurationMs": 1200000,
        "maxOutputBytes": 256000,
        "maxPermissionDenials": 6,
        "maxConsecutiveFailures": 6
      },
      "explorer.deep": {
        "maxDurationMs": 1800000,
        "maxOutputBytes": 360000
      },
      "junior.deep": {
        "maxDurationMs": 2700000
      },
      "code-worker.deep": {
        "maxDurationMs": 2700000
      }
    },
    "profiles": []
  },
  "mcp": {
    "servers": [
      {
        "name": "github",
        "description": "Built-in read-only GitHub MCP. It uses GITHUB_PERSONAL_ACCESS_TOKEN from the local environment only when the user provides one.",
        "enabled": false,
        "transport": "stdio",
        "command": "node",
        "args": ["package:scripts/github-mcp-server.js"],
        "requestTimeoutMs": 30000,
        "env": {
          "GITHUB_READ_ONLY": "1"
        },
        "envAllowlist": ["GITHUB_PERSONAL_ACCESS_TOKEN"],
        "toolRisks": {
          "get_file_contents": "read",
          "search_repositories": "read",
          "list_branches": "read",
          "list_releases": "read",
          "get_latest_release": "read",
          "list_issues": "read",
          "get_issue": "read",
          "list_pull_requests": "read",
          "get_pull_request": "read",
          "get_pull_request_files": "read"
        },
        "recommended": true,
        "category": "web"
      },
      {
        "name": "fetch",
        "description": "No-key web fetch MCP. Calls are still controlled by the runtime network policy.",
        "enabled": false,
        "transport": "stdio",
        "command": "uvx",
        "args": ["mcp-server-fetch"],
        "toolRisks": {
          "fetch": "network"
        },
        "recommended": true,
        "category": "web"
      },
      {
        "name": "duckduckgo-search",
        "description": "No-key DuckDuckGo search MCP. Public search may be rate limited.",
        "enabled": false,
        "transport": "stdio",
        "command": "uvx",
        "args": ["duckduckgo-mcp-server"],
        "toolRisks": {
          "search": "network",
          "news_search": "network"
        },
        "recommended": true,
        "category": "web"
      },
      {
        "name": "filesystem",
        "description": "Standard filesystem MCP for ecosystem compatibility. Source writes are still governed by TaxaMask permissions.",
        "enabled": false,
        "transport": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
        "toolRisks": {
          "read_file": "read",
          "list_directory": "read",
          "search_files": "read",
          "write_file": "write",
          "edit_file": "write"
        },
        "recommended": true,
        "category": "filesystem"
      }
    ]
  },
  "skills": {
    "enabled": true,
    "paths": [
      "config/skills",
      "skills/paper_distill_skill_bundle_v6_zh/skills",
      "skills/unsloth-studio-finetune-portable"
    ]
  }
}
