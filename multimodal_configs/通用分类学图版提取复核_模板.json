{
  "schema_version": "taxamask-figure-extraction-review-profile-v1",
  "profile_name": "通用分类学图版提取复核_模板",
  "profile_description": "用于复制改写的通用分类学图版模板。它不强制蚂蚁三视图，适合先作为其他类群适配的起点。",
  "target_taxon": {
    "display_name": "目标分类群",
    "scientific_scope": "",
    "tested_status": "template-needs-validation"
  },
  "taxonomy_terms": [
    "taxonomy",
    "taxonomic",
    "diagnosis",
    "description",
    "redescription",
    "morphology",
    "morphological",
    "holotype",
    "paratype",
    "type material",
    "material examined",
    "sp. nov",
    "gen. nov",
    "new species",
    "new genus"
  ],
  "rejection_terms": [
    "comparison",
    "compared",
    "versus",
    "vs.",
    "phylogeny",
    "map only",
    "table only",
    "ecology",
    "experiment"
  ],
  "auxiliary_terms": [
    "map",
    "distribution",
    "inset",
    "scale",
    "scale bar",
    "plate",
    "locality"
  ],
  "extraction_rules": {
    "caption_patterns": [
      "^Figure\\s+\\d+[A-Za-z]?[:\\.]\\s+.+",
      "^Fig\\.\\s*\\d+[A-Za-z]?[:\\.]\\s+.+",
      "^Plate\\s+\\d+[A-Za-z]?[:\\.]\\s+.+",
      "^图\\s*\\d+[A-Za-z]?[:：\\.]\\s*.+"
    ],
    "figure_reference_patterns": [
      "\\bfig\\.?\\s*(\\d+[A-Za-z]?)",
      "\\bfigure\\s*(\\d+[A-Za-z]?)",
      "\\bplate\\s*(\\d+[A-Za-z]?)",
      "图\\s*(\\d+[A-Za-z]?)"
    ],
    "section_hint_map": {
      "diagnosis": "diagnosis",
      "description": "description",
      "redescription": "description",
      "material examined": "material_examined",
      "type material": "type_material",
      "distribution": "distribution",
      "remarks": "remarks",
      "etymology": "etymology",
      "taxonomic treatment": "taxonomic_treatment",
      "species account": "species_account",
      "species accounts": "species_account",
      "identification key": "identification_key",
      "key to species": "key_to_species"
    },
    "core_section_hints": [
      "diagnosis",
      "description",
      "material_examined",
      "type_material",
      "distribution",
      "remarks",
      "etymology",
      "species_account"
    ],
    "extended_section_hints": [
      "identification_key",
      "key_to_species",
      "taxonomic_treatment",
      "species_account"
    ],
    "evidence_text_limits": {
      "figure_local_chars": 1200,
      "species_core_chars": 2200,
      "species_extended_chars": 2200
    },
    "species_name_patterns": [
      "\\b([A-Z][a-z]{2,})\\s+([a-z][a-z\\-]{2,})\\b"
    ],
    "blocked_genus_words": [
      "the",
      "this",
      "that",
      "figure",
      "plate",
      "table",
      "body",
      "head",
      "holotype",
      "paratype",
      "material",
      "type",
      "diagnosis",
      "description",
      "distribution",
      "remarks",
      "other"
    ],
    "blocked_species_words": [
      "and",
      "for",
      "with",
      "without",
      "view",
      "species",
      "nov",
      "n",
      "the",
      "this",
      "that",
      "locality"
    ]
  },
  "review_rules": {
    "acceptance_goal": "接受目标分类群的单一分类单元分类学图版，要求图像和文字证据共同支持该候选。",
    "accept_if": [
      "主体是单一分类单元或同一物种候选",
      "图版包含该类群诊断所需的主要视图或结构",
      "caption 或附近文本支持分类学用途",
      "辅助地图、比例尺或少量 inset 不改变图版主体"
    ],
    "reject_if": [
      "多分类单元比较图",
      "非目标分类群",
      "仅地图、系统树、表格、实验曲线或生态场景",
      "图像和文字证据明显不一致",
      "证据不足以判断"
    ],
    "view_schema": {
      "required_or_expected_views": [
        "habitus_or_overview",
        "diagnostic_structure"
      ],
      "acceptance_mode": "model_accept_with_parts_recorded",
      "view_terms": {
        "habitus_or_overview": [
          "habitus",
          "overview",
          "whole body",
          "general view",
          "plate"
        ],
        "diagnostic_structure": [
          "diagnostic",
          "detail",
          "structure",
          "morphology",
          "microscopy"
        ]
      }
    },
    "category_values": [
      "target_taxon_figure",
      "comparison_or_multi_species",
      "non_target_or_other",
      "uncertain"
    ],
    "decision_thresholds": {
      "accept_threshold": 0.75
    },
    "prompt": {
      "system_prompt": "你是严谨的分类学图版审稿助手。你将收到多个 PDF figure 候选，每个候选包含一张整图和分层文本证据。你的目标是只保留目标分类群的单一分类单元分类学图版。若主体不是目标类群、是多分类单元比较图、或只是地图/系统树/表格/实验图，请拒绝。请只输出 JSON，不要输出任何额外解释。",
      "user_instructions": "请按顺序审查以下 figure 候选。你必须为每个 candidate_id 返回一条结果。accept 仅在候选符合 profile 的目标分类学图版标准时为 true；detected_views 使用 profile 中定义的视图或结构字段；confidence_score 使用 0-1 浮点数。"
    },
    "mock_fallback": {
      "enabled": true,
      "accept_requires_text_hits": 2,
      "accept_requires_parts": []
    }
  }
}
