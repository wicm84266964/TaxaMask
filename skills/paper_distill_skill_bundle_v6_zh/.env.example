AGENT_WORKSPACE_ROOT=.
AGENT_EVENT_STORE=data/runtime-events.jsonl
AGENT_TASK_DATABASE=data/runtime.sqlite3
AGENT_MEMORY_ROOT=data/memory
AGENT_COMMANDER_ID=commander-local
AGENT_COMMANDER_NAME=Local Commander
AGENT_PROJECT_LOCAL_CONFIG=config/project.local.env

# Optional temporary remote planner backend for local testing only.
# Keep secrets in config/project.local.env or your shell environment.
# AGENT_PLANNER_BACKEND=openai-compatible
# AGENT_PLANNER_CHAT_COMPLETIONS_URL=https://ai.yunfei.best/v1/chat/completions
# AGENT_PLANNER_MODEL=glm-5
# AGENT_PLANNER_API_KEY=your-test-key
# AGENT_PLANNER_TIMEOUT_SECONDS=15

# Optional standalone paper distill defaults.
# PAPER_DISTILL_BACKEND=openai-compatible
# PAPER_DISTILL_MODEL=Qwen/Qwen2.5-7B-Instruct
# PAPER_DISTILL_BASE_URL=https://api.siliconflow.cn/v1
# PAPER_DISTILL_API_KEY=your-test-key
