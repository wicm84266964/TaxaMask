{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxonomy-paper-finder.local/schemas/paper-record.schema.json",
  "title": "PaperRecord",
  "type": "object",
  "required": [
    "source",
    "source_id",
    "title",
    "abstract",
    "authors",
    "published_at",
    "url"
  ],
  "properties": {
    "source": {
      "type": "string",
      "minLength": 1
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "doi": { "type": "string" },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "abstract": {
      "type": "string"
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "published_at": {
      "type": "string"
    },
    "year": { "type": "string" },
    "journal": { "type": "string" },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "landing_url": { "type": "string", "format": "uri" },
    "pdf_urls": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "query_matches": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "normalization": {
      "type": "object",
      "additionalProperties": true
    },
    "source_links": {
      "type": "object",
      "properties": {
        "landing_page": { "type": "string", "format": "uri" },
        "abstract_url": { "type": "string", "format": "uri" },
        "html_url": { "type": "string", "format": "uri" },
        "pdf_url": { "type": "string", "format": "uri" },
        "doi_url": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "reading_hints": {
      "type": "object",
      "properties": {
        "inspection_hint": { "type": "string" },
        "available_formats": {
          "type": "array",
          "items": { "type": "string" }
        },
        "priority_hint": { "type": "string", "enum": ["low", "medium", "high"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
