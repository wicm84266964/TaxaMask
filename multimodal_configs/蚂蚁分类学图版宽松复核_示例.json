  "extraction_rules": {
    "caption_patterns": [
      "^Figure\\s+\\d+[A-Za-z]?[:\\.]\\s+.+",
      "^Fig\\.\\s*\\d+[A-Za-z]?[:\\.]\\s+.+",
      "^Plate\\s+\\d+[A-Za-z]?[:\\.]\\s+.+",
      "^图\\s*\\d+[A-Za-z]?[:：\\.]\\s*.+"
    ],
    "figure_reference_patterns": [
      "\\bfig\\.?\\s*(\\d+[A-Za-z]?)",
      "\\bfigure\\s*(\\d+[A-Za-z]?)",
      "\\bplate\\s*(\\d+[A-Za-z]?)",
      "图\\s*(\\d+[A-Za-z]?)"
